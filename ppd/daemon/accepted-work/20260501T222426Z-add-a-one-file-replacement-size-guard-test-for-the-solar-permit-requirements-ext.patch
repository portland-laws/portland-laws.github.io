--- a/ppd/tests/test_solar_permit_requirements_size_guard.py
+++ b/ppd/tests/test_solar_permit_requirements_size_guard.py
@@ -0,0 +1,126 @@
+"""Replacement-size guard for the solar permit requirements extractor.
+
+This test is intentionally narrow: proposals for
+``ppd.extraction.solar_permit_requirements`` should stay small enough to review
+and should not replace the extractor with a broad generated module.
+"""
+
+from __future__ import annotations
+
+import ast
+import importlib.util
+from pathlib import Path
+import unittest
+
+
+MODULE_NAME = "ppd.extraction.solar_permit_requirements"
+MAX_PHYSICAL_LINES = 180
+MAX_TOP_LEVEL_FUNCTIONS = 14
+BANNED_RUNTIME_IMPORTS = {
+    "pandas",
+    "playwright",
+    "requests",
+    "selenium",
+}
+GENERATED_FILE_MARKERS = (
+    "auto-generated",
+    "autogenerated",
+    "generated by",
+    "do not edit",
+)
+
+
+class SolarPermitRequirementsSizeGuardTest(unittest.TestCase):
+    def test_extractor_file_exists_and_imports(self) -> None:
+        spec = importlib.util.find_spec(MODULE_NAME)
+        self.assertIsNotNone(spec, f"{MODULE_NAME} must be importable")
+        self.assertTrue(spec and spec.origin, f"{MODULE_NAME} must resolve to a file")
+        self.assertTrue(Path(str(spec.origin)).is_file())
+
+    def test_extractor_stays_under_180_physical_lines(self) -> None:
+        path = _module_path()
+        line_count = len(path.read_text(encoding="utf-8").splitlines())
+        self.assertLessEqual(
+            line_count,
+            MAX_PHYSICAL_LINES,
+            f"{MODULE_NAME} must stay under {MAX_PHYSICAL_LINES} physical lines; got {line_count}",
+        )
+
+    def test_extractor_is_not_a_broad_generated_module(self) -> None:
+        source = _module_path().read_text(encoding="utf-8")
+        reasons = _broad_generated_module_reasons(source)
+        self.assertEqual([], reasons)
+
+    def test_guard_rejects_synthetic_broad_generated_module(self) -> None:
+        broad_source = '\n'.join(
+            [
+                '"""Auto-generated solar permit requirements model. Do not edit."""',
+                'from dataclasses import dataclass',
+                'from enum import Enum',
+                'import requests',
+                '',
+                'class SolarRequirementKind(Enum):',
+                '    FACT = "fact"',
+                '',
+                '@dataclass',
+                'class SolarRequirementRecord:',
+                '    id: str',
+                '    action: str',
+            ]
+            + [f'def generated_helper_{index}():\n    return {index}' for index in range(16)]
+        )
+        reasons = _broad_generated_module_reasons(broad_source)
+        self.assertIn("generated file marker", reasons)
+        self.assertIn("top-level classes", reasons)
+        self.assertIn("too many top-level functions", reasons)
+        self.assertIn("banned runtime import: requests", reasons)
+
+
+def _module_path() -> Path:
+    spec = importlib.util.find_spec(MODULE_NAME)
+    if spec is None or not spec.origin:
+        raise AssertionError(f"{MODULE_NAME} must be importable")
+    return Path(spec.origin)
+
+
+def _broad_generated_module_reasons(source: str) -> list[str]:
+    reasons: list[str] = []
+    lower_header = "\n".join(source.splitlines()[:20]).lower()
+    if any(marker in lower_header for marker in GENERATED_FILE_MARKERS):
+        reasons.append("generated file marker")
+
+    tree = ast.parse(source)
+    top_level_functions = 0
+    top_level_classes = 0
+    for node in tree.body:
+        if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
+            top_level_functions += 1
+        elif isinstance(node, ast.ClassDef):
+            top_level_classes += 1
+        elif isinstance(node, (ast.Import, ast.ImportFrom)):
+            reasons.extend(_banned_import_reasons(node))
+
+    if top_level_classes:
+        reasons.append("top-level classes")
+    if top_level_functions > MAX_TOP_LEVEL_FUNCTIONS:
+        reasons.append("too many top-level functions")
+    if len(source.splitlines()) > MAX_PHYSICAL_LINES:
+        reasons.append("too many physical lines")
+    return reasons
+
+
+def _banned_import_reasons(node: ast.AST) -> list[str]:
+    imported_roots: list[str] = []
+    if isinstance(node, ast.Import):
+        imported_roots.extend(alias.name.split(".", 1)[0] for alias in node.names)
+    elif isinstance(node, ast.ImportFrom) and node.module:
+        imported_roots.append(node.module.split(".", 1)[0])
+    return [
+        f"banned runtime import: {root}"
+        for root in imported_roots
+        if root in BANNED_RUNTIME_IMPORTS
+    ]
+
+
+if __name__ == "__main__":
+    unittest.main()
