+++ b/ppd/daemon/test_repeated_no_patch_guardrail.py
@@ -0,0 +1,48 @@
+import unittest
+
+import repeated_no_patch_guardrail as guardrail
+
+
+class RepeatedNoPatchGuardrailTest(unittest.TestCase):
+    def test_guardrail_waits_until_four_trailing_failures(self):
+        rounds = [
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+            {"applied": False, "changed_files": ["ppd/daemon/a.py"], "failure_kind": "syntax_preflight"},
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+        ]
+        self.assertFalse(guardrail.should_apply_guardrail(rounds))
+
+        rounds.append({"applied": False, "changed_files": ["ppd/daemon/b.py"], "failure_kind": "validation_failed"})
+        self.assertTrue(guardrail.should_apply_guardrail(rounds))
+
+    def test_successful_applied_round_resets_trailing_count(self):
+        rounds = [
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+            {"applied": True, "changed_files": ["ppd/daemon/a.py"], "failure_kind": ""},
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+        ]
+        self.assertEqual(guardrail.consecutive_no_accepted_patch_rounds(rounds), 1)
+        self.assertFalse(guardrail.should_apply_guardrail(rounds))
+
+    def test_recovery_prompt_contains_required_constraints(self):
+        rounds = [
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+            {"applied": False, "changed_files": ["ppd/daemon/a.py"], "failure_kind": "syntax_preflight"},
+            {"applied": False, "changed_files": [], "failure_kind": "empty"},
+            {"applied": False, "changed_files": ["ppd/daemon/b.py"], "failure_kind": "syntax_preflight"},
+        ]
+        prompt = guardrail.build_recovery_prompt(rounds, "synthetic task")
+        lowered = prompt.lower()
+        self.assertIn("one narrow fixture-first file set", lowered)
+        self.assertIn("complete json file replacements", lowered)
+        self.assertIn("forbid live devhub sessions", lowered)
+        self.assertIn("forbid broad contract rewrites", lowered)
+        self.assertIn("synthetic fixture/self-test", lowered)
+
+    def test_synthetic_self_test_passes(self):
+        self.assertTrue(guardrail.synthetic_self_test())
+
+
+if __name__ == "__main__":
+    unittest.main()
