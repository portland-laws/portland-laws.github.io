--- a/ppd/tests/test_public_source_inventory_coverage.py
+++ b/ppd/tests/test_public_source_inventory_coverage.py
@@ -0,0 +1,75 @@
+import json
+import unittest
+from pathlib import Path
+
+from ppd.contracts.public_source_inventory_coverage import (
+    SOURCE_LANDSCAPE,
+    assert_valid_coverage_report,
+    build_coverage_report,
+    validate_coverage_report,
+)
+
+
+FIXTURE_DIR = Path(__file__).parent / "fixtures" / "public_source_inventory_coverage"
+
+
+class PublicSourceInventoryCoverageTests(unittest.TestCase):
+    def load_report(self):
+        return json.loads((FIXTURE_DIR / "coverage_report.json").read_text(encoding="utf-8"))
+
+    def test_fixture_coverage_report_is_valid_and_flags_missing_categories(self):
+        report = self.load_report()
+        self.assertEqual([], validate_coverage_report(report))
+        missing_ids = {item["sourceLandscapeId"] for item in report["missingCategories"]}
+        self.assertIn("devhub_public_portal", missing_ids)
+        self.assertIn("inspection_guidance", missing_ids)
+        self.assertNotIn("payment_guidance", missing_ids)
+
+    def test_build_report_from_inventory_categories_is_deterministic(self):
+        inventory = {
+            "fixtureId": "inventory-under-test",
+            "generatedAt": "2026-05-01T00:00:00Z",
+            "categories": [
+                {
+                    "categoryId": "fees",
+                    "label": "Fees",
+                    "sourceLandscapeIds": ["payment_guidance"],
+                    "authorityLabels": ["PP&D fee guidance"],
+                    "canonicalUrls": ["https://www.portland.gov/ppd/fees"],
+                    "recrawlCadenceHint": "weekly",
+                }
+            ],
+        }
+        report = build_coverage_report(inventory)
+        self.assertEqual("inventory-under-test", report["inventoryFixture"])
+        self.assertEqual(1, len(report["coverageEntries"]))
+        missing_ids = {item["sourceLandscapeId"] for item in report["missingCategories"]}
+        self.assertEqual(set(SOURCE_LANDSCAPE) - {"payment_guidance"}, missing_ids)
+
+    def test_report_rejects_live_or_private_artifacts(self):
+        report = self.load_report()
+        report["coverageEntries"][0]["tracePath"] = "ppd/data/private/trace.zip"
+        errors = validate_coverage_report(report)
+        self.assertTrue(any("forbidden" in error for error in errors))
+
+    def test_report_rejects_unknown_or_misreported_missing_category(self):
+        report = self.load_report()
+        report["missingCategories"].append(
+            {
+                "sourceLandscapeId": "payment_guidance",
+                "description": "Already covered by fees_and_payment_guidance",
+                "status": "missing_from_fixture_inventory",
+            }
+        )
+        errors = validate_coverage_report(report)
+        self.assertTrue(any("reports covered sourceLandscapeId payment_guidance" in error for error in errors))
+
+    def test_assert_valid_coverage_report_raises_on_invalid_report(self):
+        report = self.load_report()
+        report["coverageEntries"][0]["canonicalUrls"] = ["https://devhub.portlandoregon.gov/account"]
+        with self.assertRaises(ValueError):
+            assert_valid_coverage_report(report)
+
+
+if __name__ == "__main__":
+    unittest.main()
