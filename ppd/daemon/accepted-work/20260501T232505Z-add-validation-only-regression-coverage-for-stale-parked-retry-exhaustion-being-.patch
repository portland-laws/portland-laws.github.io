+  "expected_required_repair": "append_new_fixture_first_task_before_reporting_no_eligible_tasks"
+}
--- a/ppd/tests/test_daemon_supervisor_no_eligible_tasks.py
+++ b/ppd/tests/test_daemon_supervisor_no_eligible_tasks.py
