+def _syntax_retry_guidance(results: Iterable[SyntaxPreflightResult], changed_files: tuple[str, ...]) -> str:
+    """Return deterministic retry guidance for parser-only failures."""
+
+    failed_results = [result for result in results if not result.ok]
+    if not failed_results:
+        return ""
+    failed_paths = _failed_paths(failed_results)
+    guidance = SYNTAX_REPAIR_GUIDANCE
+    if len(changed_files) > 2 or len(failed_paths) > 1:
+        names = ", ".join(failed_paths) if failed_paths else "the parser-failing file"
+        return f"{guidance} Focus the next proposal on {names}."
+    detail = " ".join((result.stdout + " " + result.stderr) for result in failed_results)
+    if TYPESCRIPT_PARSE_ERROR_RE.search(detail):
+        return f"{guidance} TypeScript parser errors TS1005, TS1109, and TS1128 usually mean a malformed token, expression, or unmatched block; repair that file before changing fixtures."
+    return guidance
+
+
+def _failed_paths(results: Iterable[SyntaxPreflightResult]) -> tuple[str, ...]:
+    paths: list[str] = []
+    for result in results:
+        if result.ok:
+            continue
+        if len(result.command) >= 4 and result.command[:3] == ("python3", "-m", "py_compile"):
+            paths.append(result.command[3])
+            continue
+        command_text = " ".join(result.command)
+        for token in command_text.split():
+            if token.startswith("ppd/") and token.endswith((".ts", ".tsx")):
+                paths.append(token.strip("'\""))
+    return tuple(dict.fromkeys(paths))
 
 
