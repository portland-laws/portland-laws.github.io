--- a/ppd/tests/test_demolition_permit_requirements_size_guard.py
+++ b/ppd/tests/test_demolition_permit_requirements_size_guard.py
@@ -0,0 +1,102 @@
+"""Replacement-size guard for the demolition permit requirements extractor.
+
+This test intentionally inspects only ppd.extraction.demolition_permit_requirements.
+It is a narrow guard against broad generated replacement modules.
+"""
+
+from __future__ import annotations
+
+import ast
+from pathlib import Path
+import unittest
+
+
+MODULE_PATH = (
+    Path(__file__).resolve().parents[1]
+    / "extraction"
+    / "demolition_permit_requirements.py"
+)
+MAX_PHYSICAL_LINES = 180
+GENERATED_MARKERS = (
+    "do not edit",
+    "auto-generated",
+    "autogenerated",
+    "generated by",
+    "generated module",
+)
+BROAD_GENERATED_IMPORTS = {
+    "dataclasses",
+    "pydantic",
+    "attrs",
+    "attr",
+}
+
+
+class DemolitionPermitRequirementsSizeGuardTest(unittest.TestCase):
+    def _source(self) -> str:
+        self.assertTrue(
+            MODULE_PATH.exists(),
+            "ppd.extraction.demolition_permit_requirements must exist",
+        )
+        return MODULE_PATH.read_text(encoding="utf-8")
+
+    def test_extractor_stays_under_replacement_size_limit(self) -> None:
+        source = self._source()
+        physical_lines = source.splitlines()
+
+        self.assertLessEqual(
+            len(physical_lines),
+            MAX_PHYSICAL_LINES,
+            "ppd.extraction.demolition_permit_requirements must stay under "
+            f"{MAX_PHYSICAL_LINES} physical lines; split broad generated logic "
+            "into narrower reviewed tasks instead",
+        )
+
+    def test_extractor_has_no_dataclasses_or_generated_module_markers(self) -> None:
+        source = self._source()
+        lowered_source = source.lower()
+        tree = ast.parse(source, filename=str(MODULE_PATH))
+
+        for marker in GENERATED_MARKERS:
+            self.assertNotIn(
+                marker,
+                lowered_source,
+                f"generated-module marker is not allowed: {marker}",
+            )
+
+        for node in ast.walk(tree):
+            if isinstance(node, ast.Import):
+                imported_names = {alias.name.split(".", 1)[0] for alias in node.names}
+                blocked = imported_names.intersection(BROAD_GENERATED_IMPORTS)
+                self.assertFalse(
+                    blocked,
+                    f"broad generated-module imports are not allowed: {sorted(blocked)}",
+                )
+            elif isinstance(node, ast.ImportFrom):
+                module_name = (node.module or "").split(".", 1)[0]
+                self.assertNotIn(
+                    module_name,
+                    BROAD_GENERATED_IMPORTS,
+                    f"broad generated-module import is not allowed: {module_name}",
+                )
+            elif isinstance(node, ast.ClassDef):
+                decorator_names = {_decorator_name(item) for item in node.decorator_list}
+                self.assertNotIn(
+                    "dataclass",
+                    decorator_names,
+                    "dataclass-decorated classes are not allowed in this extractor",
+                )
+
+
+def _decorator_name(node: ast.AST) -> str:
+    if isinstance(node, ast.Name):
+        return node.id
+    if isinstance(node, ast.Attribute):
+        return node.attr
+    if isinstance(node, ast.Call):
+        return _decorator_name(node.func)
+    return ""
+
+
+if __name__ == "__main__":
+    unittest.main()
