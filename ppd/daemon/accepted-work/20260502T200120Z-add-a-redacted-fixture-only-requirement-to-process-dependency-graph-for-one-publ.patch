--- a/ppd/tests/test_requirement_process_dependency_graph.py
+++ b/ppd/tests/test_requirement_process_dependency_graph.py
@@ -0,0 +1,192 @@
+"""Validate fixture-only PP&D requirement-to-process dependency graphs."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any
+
+
+FIXTURE_PATH = (
+    Path(__file__).parent
+    / "fixtures"
+    / "requirement_process_dependency_graph"
+    / "public_building_permit_graph.json"
+)
+
+REQUIRED_NODE_TYPES = {
+    "source_evidence",
+    "extracted_obligation",
+    "required_document",
+    "user_fact",
+    "stop_gate",
+    "draft_plan_node",
+}
+
+FORBIDDEN_TEXT_MARKERS = (
+    "cookie",
+    "password",
+    "storage_state",
+    "auth_state",
+    "trace.zip",
+    "screenshot",
+    "captcha",
+    "mfa",
+    "payment card",
+)
+
+
+class RequirementProcessGraphError(AssertionError):
+    """Raised when the committed graph fixture violates PP&D guardrails."""
+
+
+def test_public_building_permit_requirement_process_graph_fixture() -> None:
+    graph = _load_graph()
+    _validate_graph(graph)
+
+
+def _load_graph() -> dict[str, Any]:
+    with FIXTURE_PATH.open("r", encoding="utf-8") as fixture_file:
+        data = json.load(fixture_file)
+    if not isinstance(data, dict):
+        raise RequirementProcessGraphError("graph fixture must be a JSON object")
+    return data
+
+
+def _validate_graph(graph: dict[str, Any]) -> None:
+    if graph.get("schemaVersion") != 1:
+        raise RequirementProcessGraphError("graph schemaVersion must be 1")
+    if graph.get("fixtureOnly") is not True:
+        raise RequirementProcessGraphError("graph must be marked fixtureOnly")
+
+    redaction_policy = graph.get("redactionPolicy")
+    if not isinstance(redaction_policy, dict):
+        raise RequirementProcessGraphError("graph requires a redactionPolicy object")
+    expected_redaction_flags = {
+        "valuesAreRedacted": True,
+        "privateDevhubStateIncluded": False,
+        "rawCrawlOutputIncluded": False,
+        "downloadedDocumentsIncluded": False,
+    }
+    for key, expected_value in expected_redaction_flags.items():
+        if redaction_policy.get(key) is not expected_value:
+            raise RequirementProcessGraphError(f"redactionPolicy.{key} must be {expected_value!r}")
+
+    evidence = graph.get("sourceEvidence")
+    if not isinstance(evidence, list) or not evidence:
+        raise RequirementProcessGraphError("graph requires sourceEvidence records")
+    evidence_ids = _validate_source_evidence(evidence)
+
+    nodes = graph.get("nodes")
+    if not isinstance(nodes, list) or not nodes:
+        raise RequirementProcessGraphError("graph requires nodes")
+    node_ids = _validate_nodes(nodes, evidence_ids)
+
+    edges = graph.get("edges")
+    if not isinstance(edges, list) or not edges:
+        raise RequirementProcessGraphError("graph requires edges")
+    _validate_edges(edges, node_ids, evidence_ids)
+
+    graph_text = json.dumps(graph, sort_keys=True).lower()
+    for marker in FORBIDDEN_TEXT_MARKERS:
+        if marker in graph_text:
+            raise RequirementProcessGraphError(f"graph contains forbidden private or unsafe marker {marker!r}")
+
+
+def _validate_source_evidence(records: list[Any]) -> set[str]:
+    evidence_ids: set[str] = set()
+    for index, record in enumerate(records):
+        if not isinstance(record, dict):
+            raise RequirementProcessGraphError(f"sourceEvidence[{index}] must be an object")
+        evidence_id = _required_text(record, "id", f"sourceEvidence[{index}]")
+        if evidence_id in evidence_ids:
+            raise RequirementProcessGraphError(f"duplicate source evidence id {evidence_id}")
+        evidence_ids.add(evidence_id)
+        url = _required_text(record, "url", evidence_id)
+        if not url.startswith("https://www.portland.gov/ppd"):
+            raise RequirementProcessGraphError(f"source evidence {evidence_id} must cite a public PP&D URL")
+        _required_text(record, "title", evidence_id)
+        _required_text(record, "capturedAt", evidence_id)
+        _required_text(record, "citation", evidence_id)
+    return evidence_ids
+
+
+def _validate_nodes(nodes: list[Any], evidence_ids: set[str]) -> set[str]:
+    node_ids: set[str] = set()
+    node_types: set[str] = set()
+    for index, node in enumerate(nodes):
+        if not isinstance(node, dict):
+            raise RequirementProcessGraphError(f"nodes[{index}] must be an object")
+        node_id = _required_text(node, "id", f"nodes[{index}]")
+        if node_id in node_ids:
+            raise RequirementProcessGraphError(f"duplicate node id {node_id}")
+        node_ids.add(node_id)
+        node_type = _required_text(node, "type", node_id)
+        node_types.add(node_type)
+        _required_text(node, "label", node_id)
+
+        if node_type == "source_evidence":
+            source_id = _required_text(node, "sourceEvidenceId", node_id)
+            if source_id not in evidence_ids:
+                raise RequirementProcessGraphError(f"source node {node_id} references unknown evidence {source_id}")
+        else:
+            _validate_evidence_refs(node, evidence_ids, f"node {node_id}")
+            if node.get("redactedValue") != "[REDACTED]":
+                raise RequirementProcessGraphError(f"node {node_id} must keep values redacted")
+
+        if node_type == "draft_plan_node":
+            if node.get("reversible") is not True:
+                raise RequirementProcessGraphError(f"draft plan node {node_id} must be reversible")
+            if node.get("draftOnly") is not True:
+                raise RequirementProcessGraphError(f"draft plan node {node_id} must be draftOnly")
+        if node_type == "stop_gate" and node.get("defaultState") != "blocked":
+            raise RequirementProcessGraphError(f"stop gate {node_id} must default to blocked")
+
+    missing_types = REQUIRED_NODE_TYPES.difference(node_types)
+    if missing_types:
+        raise RequirementProcessGraphError(f"graph missing required node types: {sorted(missing_types)}")
+    return node_ids
+
+
+def _validate_edges(edges: list[Any], node_ids: set[str], evidence_ids: set[str]) -> None:
+    relations: set[str] = set()
+    for index, edge in enumerate(edges):
+        if not isinstance(edge, dict):
+            raise RequirementProcessGraphError(f"edges[{index}] must be an object")
+        from_node = _required_text(edge, "from", f"edges[{index}]")
+        to_node = _required_text(edge, "to", f"edges[{index}]")
+        relation = _required_text(edge, "relation", f"edge {from_node}->{to_node}")
+        relations.add(relation)
+        if from_node not in node_ids:
+            raise RequirementProcessGraphError(f"edge references unknown from node {from_node}")
+        if to_node not in node_ids:
+            raise RequirementProcessGraphError(f"edge references unknown to node {to_node}")
+        _validate_evidence_refs(edge, evidence_ids, f"edge {from_node}->{to_node}")
+
+    required_relations = {
+        "supports_extraction",
+        "requires_document",
+        "requires_user_fact",
+        "drives_reversible_draft_plan",
+        "blocks_until_requirements_known",
+        "limits_plan_to_draft_only",
+    }
+    missing_relations = required_relations.difference(relations)
+    if missing_relations:
+        raise RequirementProcessGraphError(f"graph missing required edge relations: {sorted(missing_relations)}")
+
+
+def _validate_evidence_refs(record: dict[str, Any], evidence_ids: set[str], context: str) -> None:
+    refs = record.get("evidenceIds")
+    if not isinstance(refs, list) or not refs:
+        raise RequirementProcessGraphError(f"{context} requires evidenceIds")
+    for ref in refs:
+        if not isinstance(ref, str) or ref not in evidence_ids:
+            raise RequirementProcessGraphError(f"{context} references unknown evidence id {ref!r}")
+
+
+def _required_text(record: dict[str, Any], key: str, context: str) -> str:
+    value = record.get(key)
+    if not isinstance(value, str) or not value.strip():
+        raise RequirementProcessGraphError(f"{context} requires non-empty string field {key}")
+    return value
