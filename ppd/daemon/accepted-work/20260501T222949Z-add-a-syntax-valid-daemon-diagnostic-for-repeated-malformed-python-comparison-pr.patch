--- a/ppd/tests/test_daemon_proposal_syntax_diagnostics.py
+++ b/ppd/tests/test_daemon_proposal_syntax_diagnostics.py
@@ -0,0 +1,73 @@
+from __future__ import annotations
+
+import json
+from pathlib import Path
+import unittest
+
+from ppd.daemon.proposal_syntax_diagnostics import (
+    classify_repeated_syntax_failures,
+    malformed_fragments,
+)
+
+
+FIXTURE_PATH = (
+    Path(__file__).parent
+    / "fixtures"
+    / "daemon_diagnostics"
+    / "repeated_malformed_comparison_python_proposals.json"
+)
+
+
+class DaemonProposalSyntaxDiagnosticsTest(unittest.TestCase):
+    def load_fixture(self) -> dict:
+        return json.loads(FIXTURE_PATH.read_text(encoding="utf-8"))
+
+    def test_repeated_malformed_comparison_syntax_stops_same_task_retry(self) -> None:
+        fixture = self.load_fixture()
+        result = classify_repeated_syntax_failures(
+            fixture["proposals"],
+            minimum_repetitions=fixture["minimumRepetitions"],
+        )
+
+        self.assertEqual(fixture["expected"]["diagnostic"], result["diagnostic"])
+        self.assertIs(result["stop_condition"], True)
+        self.assertEqual(fixture["expected"]["syntax_failure_count"], result["syntax_failure_count"])
+        self.assertEqual(
+            fixture["expected"]["malformed_fragments"],
+            result["malformed_fragments"],
+        )
+        self.assertIn("syntax-first guard", result["retry_guidance"])
+        self.assertIn("smallest file set", result["retry_guidance"])
+
+    def test_non_syntax_failure_does_not_trigger_stop_condition(self) -> None:
+        result = classify_repeated_syntax_failures(
+            [
+                {
+                    "failure_kind": "validation",
+                    "validation_results": [
+                        {
+                            "returncode": 1,
+                            "stderr": "AssertionError: expected seven categories",
+                        }
+                    ],
+                }
+            ],
+            minimum_repetitions=1,
+        )
+
+        self.assertEqual("no_repeated_syntax_failure", result["diagnostic"])
+        self.assertIs(result["stop_condition"], False)
+        self.assertEqual([], result["malformed_fragments"])
+
+    def test_fragment_detection_keeps_known_examples_explicit(self) -> None:
+        fragments = malformed_fragments(
+            {
+                "stderr": "SyntaxError near confidence 1.0 and return 0.0 list[str]"
+            }
+        )
+
+        self.assertEqual(["confidence 1", "confidence 1.0", "return 0.0 list[str]"], fragments)
+
+
+if __name__ == "__main__":
+    unittest.main()
