--- a/ppd/daemon/proposal_syntax_diagnostics.py
+++ b/ppd/daemon/proposal_syntax_diagnostics.py
@@ -0,0 +1,94 @@
+"""Diagnostics for repeated syntax-invalid daemon proposals.
+
+The daemon records failed proposal manifests after validation rollback. This module
+keeps the retry guidance deterministic when several attempts against the same
+target task fail before Python can compile.
+"""
+
+from __future__ import annotations
+
+from typing import Any
+
+SYNTAX_FAILURE_MARKERS = (
+    "SyntaxError",
+    "py_compile",
+    "TS1005",
+    "TS1109",
+    "TS1128",
+)
+
+MALFORMED_PYTHON_FRAGMENTS = (
+    "confidence 1",
+    "confidence 1.0",
+    "return 0.0 list[str]",
+)
+
+RECOMMENDED_RETRY_GUIDANCE = (
+    "Stop retrying the same target task as a broad implementation. Add or run a "
+    "syntax-first guard, reduce the proposal to the smallest file set, and return "
+    "only code that compiles before broad validation resumes."
+)
+
+
+def _string_values(value: Any) -> list[str]:
+    if isinstance(value, str):
+        return [value]
+    if isinstance(value, dict):
+        values: list[str] = []
+        for nested in value.values():
+            values.extend(_string_values(nested))
+        return values
+    if isinstance(value, list):
+        values = []
+        for nested in value:
+            values.extend(_string_values(nested))
+        return values
+    return []
+
+
+def proposal_failure_text(proposal: dict[str, Any]) -> str:
+    """Return compact searchable text for one daemon proposal result."""
+
+    return "\n".join(_string_values(proposal))
+
+
+def is_syntax_failure(proposal: dict[str, Any]) -> bool:
+    """Return True when validation output points to parser/compiler failure."""
+
+    text = proposal_failure_text(proposal)
+    return any(marker in text for marker in SYNTAX_FAILURE_MARKERS)
+
+
+def malformed_fragments(proposal: dict[str, Any]) -> list[str]:
+    """Return known malformed generated-code fragments present in a proposal."""
+
+    text = proposal_failure_text(proposal)
+    return [fragment for fragment in MALFORMED_PYTHON_FRAGMENTS if fragment in text]
+
+
+def classify_repeated_syntax_failures(
+    proposals: list[dict[str, Any]],
+    minimum_repetitions: int = 2,
+) -> dict[str, Any]:
+    """Classify whether recent failures should stop same-task broad retries.
+
+    The input is intentionally plain JSON-shaped data so tests can exercise the
+    same records the daemon persists in progress/result logs.
+    """
+
+    syntax_failures = [proposal for proposal in proposals if is_syntax_failure(proposal)]
+    fragments: list[str] = []
+    for proposal in syntax_failures:
+        for fragment in malformed_fragments(proposal):
+            if fragment not in fragments:
+                fragments.append(fragment)
+
+    stop_condition = len(syntax_failures) >= minimum_repetitions and bool(fragments)
+    return {
+        "diagnostic": "repeated_syntax_failure" if stop_condition else "no_repeated_syntax_failure",
+        "stop_condition": stop_condition,
+        "syntax_failure_count": len(syntax_failures),
+        "malformed_fragments": fragments,
+        "recommended_file_set": "one implementation file plus one focused test or fixture at most",
+        "retry_guidance": RECOMMENDED_RETRY_GUIDANCE if stop_condition else "No syntax-first retry stop is required.",
+    }
