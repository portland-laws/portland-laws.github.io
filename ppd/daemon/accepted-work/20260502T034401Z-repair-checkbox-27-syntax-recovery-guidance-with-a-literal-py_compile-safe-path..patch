+## Literal Checkbox-27a Template
+
+When checkbox-27a is the selected or lowest incomplete prerequisite, the worker should return this exact file shape and only adjust whitespace if needed. This template is intentionally ordinary Python so the daemon can recover from repeated `if confidence 1:` syntax failures.
+
+```python
+import json
+import unittest
+from pathlib import Path
+
+
+FIXTURE_PATH = (
+    Path(__file__).parent
+    / "fixtures"
+    / "lifecycle"
+    / "permit_lifecycle_requirement_extraction_expected_output.json"
+)
+
+ACCEPTED_CATEGORY_IDS = {
+    "extension_eligibility",
+    "reactivation_eligibility",
+    "cancellation_eligibility",
+    "refund_eligibility",
+    "inspection_scheduling",
+    "inspection_result_follow_up",
+    "fee_payment_checkpoints",
+    "explicit_confirmation_gates",
+}
+
+
+def _load_category_records():
+    with FIXTURE_PATH.open("r", encoding="utf-8") as handle:
+        payload = json.load(handle)
+    records = payload.get("categoryRecords")
+    if not isinstance(records, list):
+        raise AssertionError("categoryRecords must be a list")
+    return records
+
+
+def _assert_valid_category_records(records):
+    if len(records) != 8:
+        raise AssertionError("categoryRecords must contain exactly eight records")
+    seen = set()
+    for record in records:
+        _assert_valid_category_record(record)
+        key = (
+            record.get("categoryId"),
+            record.get("action"),
+            record.get("object"),
+            tuple(record.get("sourceEvidenceIds", [])),
+        )
+        if key in seen:
+            raise AssertionError("category record identity must be unique")
+        seen.add(key)
+
+
+def _assert_valid_category_record(record):
+    if not isinstance(record, dict):
+        raise AssertionError("category record must be an object")
+    category_id = record.get("categoryId")
+    if category_id not in ACCEPTED_CATEGORY_IDS:
+        raise AssertionError("categoryId must be accepted")
+    source_evidence_ids = record.get("sourceEvidenceIds")
+    if not isinstance(source_evidence_ids, list) or not source_evidence_ids:
+        raise AssertionError("sourceEvidenceIds must be a non-empty list")
+    evidence = record.get("evidence")
+    if not isinstance(evidence, list):
+        raise AssertionError("evidence must be a list")
+    local_evidence_ids = set()
+    for item in evidence:
+        if not isinstance(item, dict):
+            raise AssertionError("evidence entries must be objects")
+        evidence_id = item.get("evidenceId")
+        if not isinstance(evidence_id, str) or not evidence_id:
+            raise AssertionError("evidenceId must be a non-empty string")
+        local_evidence_ids.add(evidence_id)
+    for evidence_id in source_evidence_ids:
+        if evidence_id not in local_evidence_ids:
+            raise AssertionError("sourceEvidenceIds must reference local evidence")
+    confidence = record.get("confidence")
+    if not isinstance(confidence, (int, float)):
+        raise AssertionError("confidence must be numeric")
+    if not 0 <= confidence <= 1:
+        raise AssertionError("confidence must be between 0 and 1")
+    if record.get("stopGate") is True:
+        classification = record.get("classification")
+        if not isinstance(classification, str):
+            raise AssertionError("stop gate classification must be a string")
+        if not classification.endswith("_stop_gate"):
+            raise AssertionError("stop gate classification must end with _stop_gate")
+
+
+class PermitLifecycleRequirementExtractionMutationTests(unittest.TestCase):
+    def test_committed_category_records_fixture_is_valid(self):
+        records = _load_category_records()
+        _assert_valid_category_records(records)
+
+
+if __name__ == "__main__":
+    unittest.main()
+```
