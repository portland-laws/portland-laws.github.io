+    "/my-permits",
+    "/permitrequest",
+    "/permit-request",
+    "/dashboard",
+    "/user",
+    "/users",
+)
+
+RAW_RESPONSE_BODY_KEYS = {
+    "body",
+    "html",
+    "rawbody",
+    "rawcontent",
+    "rawhtml",
+    "rawresponsebody",
+    "rawtext",
+    "responsebody",
+    "text",
+}
+
+CREDENTIAL_KEYS = {
