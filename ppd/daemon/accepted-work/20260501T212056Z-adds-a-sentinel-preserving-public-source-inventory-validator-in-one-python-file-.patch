+"""Syntax-first import target and validator for PP&D public source inventory.
+
+This module keeps the syntax-first sentinel stable while exposing small,
+plain-function validation helpers for fixture-only public source inventory
+checks. Inventory records are manifest-style metadata only; they must not carry
+raw response bodies, credentials, browser traces, screenshots, downloaded
+documents, private DevHub account paths, or entries without provenance.
 """
+
+from __future__ import annotations
+
+from collections.abc import Mapping, Sequence
+from urllib.parse import urlparse
+
 
 MODULE_PURPOSE = "syntax_first_public_source_inventory_validation"
 PUBLIC_SOURCE_INVENTORY_VALIDATOR_READY = False
+
+ALLOWED_PUBLIC_HOSTS = {
