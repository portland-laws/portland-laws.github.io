+      "shouldAppend": true
+    },
+    {
+      "name": "planning timed out after board exhaustion",
+      "completeCount": 90,
+      "taskCount": 90,
+      "noAvailableTask": true,
+      "planningStatus": "codex_planning_timed_out",
+      "shouldAppend": true
