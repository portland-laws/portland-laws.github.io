+def validate_guardrailed_proposal(
+    proposal: Mapping[str, Any],
+    decision: RepeatedNoPatchDecision,
+) -> list[str]:
+    """Return deterministic preflight errors for proposals made while active."""
+
+    if not decision.active:
+        return []
+
+    errors: list[str] = []
+    files = proposal.get("files")
+    if not isinstance(files, list) or not files:
+        return ["active repeated-no-patch guardrail requires a non-empty files array"]
+    if len(files) > 2:
+        errors.append("active repeated-no-patch guardrail allows at most two daemon-local files")
+
+    for index, file_entry in enumerate(files):
+        if not isinstance(file_entry, dict):
+            errors.append(f"files[{index}] must be an object")
+            continue
+        path = file_entry.get("path")
+        content = file_entry.get("content")
+        if not isinstance(path, str) or not path.startswith(DAEMON_ONLY_PREFIX):
+            errors.append(f"files[{index}].path must stay under {DAEMON_ONLY_PREFIX}")
+        if isinstance(path, str) and any(path.startswith(prefix) for prefix in FORBIDDEN_PATH_PREFIXES):
+            errors.append(f"files[{index}].path is forbidden by repeated-no-patch guardrail: {path}")
+        if not isinstance(content, str):
+            errors.append(f"files[{index}].content must be a complete replacement string")
+
+    combined_text = json.dumps(proposal, sort_keys=True)
+    lowered = combined_text.lower()
+    for phrase in FORBIDDEN_PROMPT_TEXT:
+        if phrase.lower() in lowered:
+            errors.append(f"proposal mentions forbidden recovery scope: {phrase}")
+    return errors
+
+
+def _synthetic_self_test() -> None:
+    failed_round = {
+        "applied": False,
+        "validation_passed": False,
+        "failure_kind": "syntax_preflight",
+        "changed_files": ["ppd/daemon/repeated_no_patch_guardrail.py"],
+        "errors": ["Syntax preflight failed"],
+    }
+    accepted_round = {
+        "applied": True,
+        "validation_passed": True,
+        "failure_kind": "",
+        "changed_files": ["ppd/daemon/stale_blocked_task_reconciliation.py"],
+        "errors": [],
+    }
+
+    inactive = decide_repeated_no_patch_guardrail([accepted_round, failed_round, failed_round, failed_round])
+    assert inactive.active is False
+    assert inactive.consecutive_rounds == 3
+
+    active = decide_repeated_no_patch_guardrail([accepted_round, failed_round, failed_round, failed_round, failed_round])
+    assert active.active is True
+    assert active.consecutive_rounds == 4
+    prompt = active.prompt_suffix()
+    assert "one narrow fixture-first daemon repair file set" in prompt
+    assert "complete file replacements" in prompt
+    assert "ppd/daemon/" in prompt
+    assert "live DevHub sessions" in prompt
+    assert "broad rewrites" in prompt
+
+    valid_proposal = {
+        "summary": "Add a daemon-local recovery self-test.",
+        "impact": "Constrains repeated failed rounds to syntax-valid daemon repair.",
+        "files": [
+            {
+                "path": "ppd/daemon/repeated_no_patch_guardrail.py",
+                "content": "print('fixture-only self-test')\n",
+            }
+        ],
+        "validation_commands": [["python3", "-m", "py_compile", "ppd/daemon/repeated_no_patch_guardrail.py"]],
+    }
+    assert validate_guardrailed_proposal(valid_proposal, active) == []
+
+    invalid_proposal = {
+        "summary": "Rewrite contracts and open an authenticated DevHub workflow.",
+        "impact": "Too broad.",
+        "files": [
+            {"path": "ppd/tests/fixtures/devhub/form_state.json", "content": "{}\n"},
+            {"path": "ppd/contracts/processes.py", "content": "# broad rewrite\n"},
+            {"path": "ppd/daemon/extra.py", "content": "# extra\n"},
+        ],
+    }
+    invalid_errors = validate_guardrailed_proposal(invalid_proposal, active)
+    assert any("at most two" in error for error in invalid_errors)
+    assert any("ppd/daemon/" in error for error in invalid_errors)
+    assert any("authenticated DevHub" in error for error in invalid_errors)
+    assert any("broad contract rewrite" in error for error in invalid_errors)
+
+
+def main() -> int:
