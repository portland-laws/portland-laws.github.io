+def fixture_shape_retry_prompt_guidance(
+    matched_markers: Iterable[str],
+    *,
+    fixture_paths: Iterable[str] = (),
+    fixture_shapes: Iterable[dict[str, object]] = (),
+) -> str:
+    """Build deterministic daemon prompt guidance for fixture-shape retries."""
+
+    unique_markers = tuple(dict.fromkeys(str(marker) for marker in matched_markers if str(marker).strip()))
+    marker_text = ", ".join(unique_markers) if unique_markers else "missing required fixture fields"
+    paths = tuple(dict.fromkeys(str(path) for path in fixture_paths if str(path).strip()))
+    path_text = ", ".join(paths) if paths else "the committed JSON fixture named by the failing test"
+    shape_text = _format_fixture_shapes(fixture_shapes)
+    return (
+        "Recent PP&D validation failed because a validator expected fields that were absent "
+        f"from a JSON fixture ({marker_text}). Before writing or retrying the validator, "
+        f"inspect the committed fixture shape for {path_text} with ppd/daemon/fixture_shape.py "
+        "or the existing fixture-shape helper, then constrain the retry to the fields that "
+        "actually exist unless the selected task explicitly permits replacing that fixture. "
+        "Do not introduce broad shared contracts, live crawl code, authenticated DevHub "
+        "automation, or fixture rewrites for this retry."
+        f"{shape_text}"
+    )
+
+
+def _join_context(failure_context: Iterable[str]) -> str:
+    return "\n".join(str(item) for item in failure_context)
+
+
+def _extract_fixture_paths(context_text: str) -> tuple[str, ...]:
+    return tuple(dict.fromkeys(match.group(0) for match in JSON_FIXTURE_PATH_RE.finditer(context_text)))
+
+
+def _describe_fixture_paths(repo_root: Optional[Path], fixture_paths: Iterable[str]) -> tuple[dict[str, object], ...]:
+    if repo_root is None:
+        return ()
+    shapes: list[dict[str, object]] = []
+    for fixture_path in fixture_paths:
+        try:
+            shapes.append(describe_json_fixture(repo_root, fixture_path).to_dict())
+        except ValueError as exc:
+            shapes.append({"fixture_path": fixture_path, "error": str(exc)})
+    return tuple(shapes)
+
+
+def _format_fixture_shapes(fixture_shapes: Iterable[dict[str, object]]) -> str:
+    summaries: list[str] = []
+    for shape in fixture_shapes:
+        fixture_path = str(shape.get("fixture_path", ""))
+        if "error" in shape:
+            summaries.append(f"{fixture_path}: error={shape['error']}")
+            continue
+        top_level_keys = ", ".join(str(item) for item in shape.get("top_level_keys", []))
+        list_fields = ", ".join(str(item) for item in shape.get("list_fields", []))
+        first_object_keys = shape.get("first_object_keys", {})
+        summaries.append(
+            f"{fixture_path}: top_level_keys=[{top_level_keys}], "
+            f"list_fields=[{list_fields}], first_object_keys={first_object_keys}"
+        )
+    if not summaries:
+        return ""
+    return " Committed fixture shape: " + " | ".join(summaries)
+
+
